{
  "name": "aurisleft",
  "private": true,
  "version": "0.2.0-beta",
  "description": "AurisLeft desktop music player (Electron) — 测试版",
  "author": "AurisLeft Contributors",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm run web:dev\" \"npm run electron:dev\"",
    "electron:dev": "wait-on tcp:1420 && cross-env VITE_DEV_SERVER_URL=http://localhost:1420 electron .",
    "electron:start": "electron .",
    "web:dev": "vite",
    "web:build": "tsc --noEmit && vite build",
    "web:preview": "vite preview",
    "build": "npm run web:build && electron-builder",
    "typecheck": "tsc --noEmit",
    "pack": "electron-builder --dir",
    "dist": "npm run web:build && electron-builder --win"
  },
  "dependencies": {
    "lucide-react": "^1.14.0",
    "music-metadata": "^11.13.0",
    "react": "^19.1.0",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.14.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.1.2",
    "electron-builder": "^25.1.8",
    "prettier": "^3.8.3",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.aurisleft.desktop",
    "productName": "AurisLeft 测试版",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
